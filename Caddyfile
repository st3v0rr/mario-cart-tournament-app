{$DOMAIN} {
    # Enforce minimum TLS 1.2, prefer TLS 1.3
    tls {
        protocols tls1.2 tls1.3
    }

    # Response compression
    encode zstd gzip

    # Security headers (defense-in-depth alongside app-level Helmet)
    header {
        # Remove server identification
        -Server

        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"

        # Force HTTPS for mixed content (app sets full CSP, this adds upgrade directive)
        Content-Security-Policy "upgrade-insecure-requests"

        # Permissions policy (mirrored from app-level Helmet config)
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    }

    reverse_proxy app:3000
}
